{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.bank/commercial-lending-spreading-ai-pilot/pilot-scorecard-row.schema.json",
  "title": "Pilot Scorecard Row",
  "type": "object",
  "required": [
    "case_id",
    "path",
    "document_id",
    "normalized_line",
    "material",
    "manual_value",
    "candidate_value",
    "manual_minutes",
    "candidate_minutes",
    "exception_flag",
    "certified"
  ],
  "properties": {
    "case_id": { "type": "string", "minLength": 1 },
    "path": {
      "type": "string",
      "enum": ["ncino_automated_spreading", "salesforce_native_staging", "manual_ncino_control"]
    },
    "borrower": { "type": "string" },
    "loan_or_opportunity": { "type": "string" },
    "document_id": { "type": "string", "minLength": 1 },
    "statement_type": { "type": "string" },
    "fiscal_period": { "type": "string" },
    "normalized_line": { "type": "string", "minLength": 1 },
    "material": { "type": "string", "enum": ["true", "false"] },
    "manual_value": { "type": "string" },
    "candidate_value": { "type": "string" },
    "manual_minutes": { "type": "string" },
    "candidate_minutes": { "type": "string" },
    "exception_flag": { "type": "string", "enum": ["true", "false"] },
    "certified": { "type": "string", "enum": ["true", "false"] },
    "error_type": { "type": "string" },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}

