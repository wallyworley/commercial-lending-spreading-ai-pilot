{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.bank/commercial-lending-spreading-ai-pilot/spread-parser-output.schema.json",
  "title": "Spread Parser Output",
  "type": "object",
  "required": [
    "document_id",
    "statement_type",
    "fiscal_period",
    "parser_version",
    "candidates"
  ],
  "properties": {
    "document_id": { "type": "string", "minLength": 1 },
    "borrower": { "type": "string" },
    "loan_or_opportunity": { "type": "string" },
    "statement_type": {
      "type": "string",
      "enum": ["balance_sheet", "income_statement", "cash_flow", "tax_return", "schedule", "other"]
    },
    "fiscal_period": { "type": "string", "minLength": 1 },
    "parser_version": { "type": "string", "minLength": 1 },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "normalized_line",
          "raw_label",
          "raw_value",
          "normalized_value",
          "source_page",
          "confidence",
          "status"
        ],
        "properties": {
          "normalized_line": { "type": "string", "minLength": 1 },
          "raw_label": { "type": "string", "minLength": 1 },
          "raw_value": { "type": "string", "minLength": 1 },
          "normalized_value": { "type": "number" },
          "evidence_id": { "type": "string" },
          "source_page": { "type": "integer", "minimum": 1 },
          "source_coordinates": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "exception_reason": { "type": ["string", "null"] },
          "status": {
            "type": "string",
            "enum": ["draft", "exception"]
          }
        },
        "additionalProperties": false
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason", "severity"],
        "properties": {
          "reason": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["warning", "hard_stop"] },
          "evidence_id": { "type": "string" },
          "source_page": { "type": "integer", "minimum": 1 },
          "raw_text": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
