<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Lifecycle record for a spread review exception.</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <label>Spread Exception</label>
    <nameField>
        <displayFormat>EXC-{0000}</displayFormat>
        <label>Spread Exception Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Spread Exceptions</pluralLabel>
    <sharingModel>Private</sharingModel>
</CustomObject>

