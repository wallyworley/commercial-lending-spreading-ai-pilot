<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Variance_Pct__c</fullName>
    <formula>IF(BLANKVALUE(Manual_Value__c, 0) = 0, NULL, (BLANKVALUE(Manual_Value__c, 0) - BLANKVALUE(Candidate_Value__c, 0)) / Manual_Value__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Variance Percent</label>
    <precision>18</precision>
    <scale>2</scale>
    <type>Percent</type>
</CustomField>

